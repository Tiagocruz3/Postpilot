# =============================================================================
# App (deploy / dev)
# =============================================================================

# Supabase (Dashboard → Project Settings → API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Optional: enables Stock Image search in Composer
VITE_PIXABAY_API_KEY=your-pixabay-api-key

# Public app URL (OAuth redirects back here)
APP_URL=http://localhost:5173

# Optional: run UI without Supabase
# VITE_ENABLE_DEMO=true

# =============================================================================
# Platform owner only — set once per PostPilot deployment, never per subscriber
# Sync to Supabase: npm run supabase:secrets
# =============================================================================

# Register OAuth redirect URIs in each provider console:
# https://YOUR_PROJECT_REF.supabase.co/functions/v1/facebook-oauth-callback
# https://YOUR_PROJECT_REF.supabase.co/functions/v1/linkedin-oauth-callback
# https://YOUR_PROJECT_REF.supabase.co/functions/v1/x-oauth-callback
# https://YOUR_PROJECT_REF.supabase.co/functions/v1/meta-oauth-callback
# https://YOUR_PROJECT_REF.supabase.co/functions/v1/google-calendar-oauth-callback

# Meta / Facebook
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret

# LinkedIn
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# X (Twitter)
X_CLIENT_ID=your-x-client-id
X_CLIENT_SECRET=your-x-client-secret

# Google Calendar
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Encrypt subscriber integration tokens at rest (generate: openssl rand -base64 32)
INTEGRATION_ENCRYPTION_KEY=your-base64-32-byte-key

# --- AI (platform provides; subscribers only pick models in Settings) ---

# OpenRouter — primary for content + images when set
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_CONTENT_MODEL=google/gemini-2.5-pro
# Live web research in Compose (Research Topic)
OPENROUTER_RESEARCH_MODEL=perplexity/sonar
# Nano Banana 2 (Gemini 3.1 Flash Image Preview)
OPENROUTER_IMAGE_MODEL=google/gemini-3.1-flash-image-preview

# Lovable AI — fallback for Ads copy/images if OpenRouter key is unset
LOVABLE_API_KEY=your-lovable-api-key
LOVABLE_AI_URL=https://ai.lovable.dev/v1

# fal — video generation (Compose + AI Library)
FAL_API_KEY=your-fal-api-key
FAL_VIDEO_MODEL=fal-ai/kling-video/v2.1/master/text-to-video

# Storage: `media` (uploads) and `ai_library` (AI-generated assets) use paths:
# {workspace_id}/{user_id}/filename — workspace members can access; isolated per workspace.
